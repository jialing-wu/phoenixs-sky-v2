# Demo mode — set to "true" for mock data, no API keys needed
NEXT_PUBLIC_DEMO=true

# ── Below only needed when NEXT_PUBLIC_DEMO=false ──

# Google Calendar (Service Account)
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Todoist
TODOIST_TOKEN=

# Notion
NOTION_TOKEN=
NOTION_DB_TASKS=
NOTION_DB_DEADLINES=

# Upstash Redis (optional — syncs preferences across devices)
KV_REST_API_URL=
KV_REST_API_TOKEN=
